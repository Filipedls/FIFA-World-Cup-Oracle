# Copy this file to `.env` and fill in your key:  cp .env.example .env
#
# Get a free API-Football key at https://www.api-football.com/
# (direct api-sports.io account, or via RapidAPI). Free tier ~100 requests/day —
# the app caches responses to disk so this is plenty.

WORLD_CUP_DATA_SOURCE=balldontlie
WORLD_CUP_API_KEY=236183d6-3448-44da-9fa1-327c0ddf98ca

# WORLD_CUP_DATA_SOURCE=api_football
# WORLD_CUP_API_KEY=48b8dcc1d952264ee0e456ecf6e26fbe

# --- Optional overrides (sensible defaults shown) ---------------------------
# API-Football league id (1 = World Cup) and season (the 2026 edition).
# WORLD_CUP_LEAGUE_ID=1
# WORLD_CUP_SEASON=2026

# Bookmaker id used for Match-Winner odds (8 = Bet365 on API-Football).
# WORLD_CUP_BOOKMAKER_ID=8

# Cache: seconds before the on-disk dataset is considered stale, and where to
# store it. The cache also auto-invalidates when a fixture's kickoff has passed.
# WORLD_CUP_CACHE_TTL=600
# WORLD_CUP_CACHE_DIR=.cache
