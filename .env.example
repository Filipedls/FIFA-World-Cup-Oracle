# Copy this file to `.env` and fill in a key:  cp .env.example .env
#
# Pick ONE data provider and use a key that belongs to it.
#
#  balldontlie  (default, recommended) — free tier COVERS the 2026 season and
#               includes odds. Register: https://app.balldontlie.io/  (FIFA API)
#  api_football — https://www.api-football.com/  (note: the free tier does NOT
#               include the 2026 season, only 2022–2024)
WORLD_CUP_DATA_SOURCE=balldontlie
WORLD_CUP_API_KEY=your_key_here

# --- Optional overrides (sensible defaults shown) ---------------------------
# Season to pull (the 2026 edition).
# WORLD_CUP_SEASON=2026

# api_football only: league id (1 = World Cup) and bookmaker id (8 = Bet365).
# WORLD_CUP_LEAGUE_ID=1
# WORLD_CUP_BOOKMAKER_ID=8

# Cache: seconds before the on-disk dataset is considered stale, and where to
# store it. The cache also auto-invalidates when a fixture's kickoff has passed.
# WORLD_CUP_CACHE_TTL=600
# WORLD_CUP_CACHE_DIR=.cache
