# Copy this file to `.env`:  cp .env.example .env
#
# === Base data source (fixtures, standings, scorers) ========================
# worldcup26   - FREE, no key needed (default). Community API at worldcup26.ir.
# balldontlie  - needs a PAID key (free tier only exposes /teams).
# api_football - needs a key (free tier excludes the 2026 season).
WORLD_CUP_DATA_SOURCE=worldcup26

# Only needed for balldontlie / api_football (leave blank for worldcup26):
# WORLD_CUP_API_KEY=your_key_here

# === Betting odds (optional overlay) =======================================
# Real bookmaker odds from https://the-odds-api.com/ (free tier: 500 req/mo).
# Without this, match win probabilities come from the Poisson power model.
# THE_ODDS_API_KEY=your_odds_api_key
# WORLD_CUP_ODDS_REGIONS=us          # us | uk | eu | au (comma-separated)

# === Optional overrides (sensible defaults shown) ==========================
# WORLD_CUP_SEASON=2026
# api_football only:
# WORLD_CUP_LEAGUE_ID=1
# WORLD_CUP_BOOKMAKER_ID=8
# Cache (auto-invalidates when a fixture's kickoff has passed):
# WORLD_CUP_CACHE_TTL=600
# WORLD_CUP_CACHE_DIR=.cache
